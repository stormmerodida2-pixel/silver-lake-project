# Copy this file to .env and fill in real values.

# The backend API root - with or without a trailing slash both work (apiClient.js joins it
# correctly either way).
VITE_API_BASE_URL=http://localhost:8000/api/

# The number the floating WhatsApp button on the public site links to (international format,
# no + or leading zeros - e.g. 254700000000).
VITE_WHATSAPP_NUMBER=

# Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX), from analytics.google.com -
# Admin > Data Streams > your web stream. Leave blank to disable analytics entirely (local dev
# should stay blank so it never pollutes real traffic data).
VITE_GA_MEASUREMENT_ID=
