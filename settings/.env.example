# Copy this file to settings/.env (same folder) and fill in real values. Every variable here
# has a safe local-dev default in code (see settings/base.py) EXCEPT where noted - the app runs
# fine locally with this file absent entirely, this just documents what production actually needs.

# Django
SECRET_KEY=
# Comma-separated. No safe default in production - settings/production.py fails loudly if unset.
ALLOWED_HOSTS=localhost,127.0.0.1
# Comma-separated frontend origin(s) allowed to call the API in production.
CORS_ALLOWED_ORIGINS=
# Where email links (activation, password reset, payment/dispute links) point back to.
FRONTEND_URL=http://localhost:5173
# Only set this to true if deployed behind a reverse proxy/load balancer that terminates TLS
# itself (Render, Railway, Heroku, an nginx front end) - leave unset for a direct-to-Django
# HTTPS setup.
BEHIND_HTTPS_PROXY=

# Email (Gmail SMTP) - leave blank to write emails to sent_emails/ instead of sending for real.
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# M-Pesa (Safaricom Daraja) - sandbox by default. All of these are required once MPESA_ENV=production.
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
# Must be a publicly reachable HTTPS URL - Safaricom's servers call this directly.
MPESA_CALLBACK_URL=
# Random secret path segment appended to MPESA_CALLBACK_URL - guards the callback endpoint
# against forged "payment succeeded" requests. Generate any long random string.
MPESA_CALLBACK_SECRET=

# M-Pesa B2C (automated driver/FleetPartner payouts) - entirely optional, a separate Daraja
# product from STK Push above with its own "Go Live" application. Leave unset and payouts just
# stay on the existing manual Mark Paid flow.
MPESA_B2C_SHORTCODE=
MPESA_B2C_INITIATOR_NAME=
# Safaricom's own public certificate is used offline to RSA-encrypt your Initiator password -
# paste the resulting base64 ciphertext here, never the raw password itself.
MPESA_B2C_SECURITY_CREDENTIAL=
# Must be a publicly reachable HTTPS URL - reuses MPESA_CALLBACK_SECRET above as its own secret
# path segment, same as MPESA_CALLBACK_URL does.
MPESA_B2C_CALLBACK_URL=

# Database - leave unset for local SQLite. Set for MySQL in production:
# mysql://USER:PASSWORD@HOST:PORT/NAME
DATABASE_URL=

# Media storage (uploaded vehicle/driver photos and documents) - leave unset to use local disk,
# fine for local dev but NOT for production (most hosts wipe local disk on every deploy). Works
# with real AWS S3, Cloudflare R2, DigitalOcean Spaces, Backblaze B2, or anything else speaking
# the S3 API - set AWS_S3_ENDPOINT_URL for anything that isn't real AWS S3.
AWS_STORAGE_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_ENDPOINT_URL=
AWS_S3_REGION_NAME=auto

# SMS (Africa's Talking) - required for booking confirmation/driver-assignment SMS to actually
# send; without these set, SMS sending just fails silently the same way a misconfigured email
# server does (never blocks the booking itself). Username 'sandbox' always uses their sandbox
# environment for testing - swap to your own registered app's username to go live.
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=
# Optional - only needed once you have your own approved alphanumeric sender ID/shortcode;
# leave blank to send from Africa's Talking's shared default.
AFRICASTALKING_SENDER_ID=

# Error tracking (Sentry) - leave blank to disable entirely (local dev should stay blank).
# DSN comes from your Sentry project's Settings > Client Keys.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
# 0.0-1.0 - share of requests sampled for performance tracing (errors are always captured
# regardless of this setting).
SENTRY_TRACES_SAMPLE_RATE=0.1

# Web Push (browser notifications) - leave blank to disable entirely. Unlike everything else in
# this file, this needs no third-party account - generate your own keypair with:
#   python -c "
#   from py_vapid import Vapid02
#   import base64
#   v = Vapid02(); v.generate_keys()
#   pub = v.public_key.public_bytes(
#       __import__('cryptography.hazmat.primitives.serialization', fromlist=['Encoding']).Encoding.X962,
#       __import__('cryptography.hazmat.primitives.serialization', fromlist=['PublicFormat']).PublicFormat.UncompressedPoint,
#   )
#   priv = v.private_key.private_numbers().private_value.to_bytes(32, 'big')
#   print('VAPID_PUBLIC_KEY=' + base64.urlsafe_b64encode(pub).rstrip(b'=').decode())
#   print('VAPID_PRIVATE_KEY=' + base64.urlsafe_b64encode(priv).rstrip(b'=').decode())
#   "
# VITE_VAPID_PUBLIC_KEY in frontend/.env must be set to the same VAPID_PUBLIC_KEY value below.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIM_EMAIL=support@silverlakecarrentals.co.ke
